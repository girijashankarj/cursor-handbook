{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Type check",
      "type": "shell",
      "command": "npm run type-check",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "npm run lint",
      "group": "test",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "Test (current file)",
      "type": "shell",
      "command": "npm run test -- --testPathPattern=${relativeFile}",
      "group": "test",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run build",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always" }
    }
  ]
}
